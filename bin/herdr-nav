#!/usr/bin/env bash
# herdr-nav <left|right|up|down>
# vim-aware herdr pane navigation — the herdr equivalent of vim-tmux-navigator.
#
# If the focused pane runs (n)vim, forward ctrl+<hjkl> into it so nvim moves its
# own split (and, via the nvim-side mapping, hands focus back to herdr at edge
# splits). Otherwise move herdr's pane focus directly.
#
# Bound from ~/.config/herdr/config.toml via [[keys.command]] on ctrl+h/j/k/l.
# See herdr issue #281.
set -euo pipefail

# Runs from the herdr server, whose PATH is not our interactive shell's. Make
# sure jq and common bin dirs are reachable...
export PATH="/opt/homebrew/bin:/usr/bin:/bin:$PATH"

# ...and resolve the herdr binary explicitly: prefer PATH, fall back to the
# mise install (the `latest` symlink stays valid across `mise up herdr`).
HERDR="$(command -v herdr || true)"
[ -z "$HERDR" ] && HERDR="$HOME/.local/share/mise/installs/herdr/latest/herdr"

dir=${1:?usage: herdr-nav <left|right|up|down>}
case "$dir" in
  left)  key=ctrl+h ;;
  down)  key=ctrl+j ;;
  up)    key=ctrl+k ;;
  right) key=ctrl+l ;;
  *) echo "herdr-nav: bad direction '$dir'" >&2; exit 1 ;;
esac

info=$("$HERDR" pane process-info --current)
pane_id=$(jq -r '.result.process_info.pane_id' <<<"$info")

# Is any foreground process (n)vim? Check both the reported name and argv0.
is_vim=$(jq -r '
  [.result.process_info.foreground_processes[]? | .name, .argv0]
  | any(. != null and test("^n?vim$"; "i"))
' <<<"$info")

if [ "$is_vim" = "true" ]; then
  "$HERDR" pane send-keys "$pane_id" "$key"
else
  "$HERDR" pane focus --direction "$dir" --current
fi
